{
  "info": {
    "name": "Community Dashboard - Mobile Core",
    "description": "Core mobile Postman collection with token auto-capture and 401 refresh retry.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "auth": {
    "type": "bearer",
    "bearer": [
      {
        "key": "token",
        "value": "{{accessToken}}",
        "type": "string"
      }
    ]
  },
  "event": [
    {
      "listen": "prerequest",
      "script": {
        "type": "text/javascript",
        "exec": [
          "const token = pm.collectionVariables.get('accessToken');",
          "if (!token) { return; }",
          "const parts = token.split('.');",
          "if (parts.length !== 3) { return; }",
          "try {",
          "  const payload = JSON.parse(atob(parts[1].replace(/-/g, '+').replace(/_/g, '/')));",
          "  if (payload && payload.sub) pm.collectionVariables.set('userId', payload.sub);",
          "} catch (e) {}"
        ]
      }
    },
    {
      "listen": "test",
      "script": {
        "type": "text/javascript",
        "exec": [
          "function decodeJwt(token) {",
          "  try {",
          "    const parts = token.split('.');",
          "    if (parts.length !== 3) return null;",
          "    return JSON.parse(atob(parts[1].replace(/-/g, '+').replace(/_/g, '/')));",
          "  } catch (e) { return null; }",
          "}",
          "",
          "function saveTokens(body) {",
          "  pm.collectionVariables.set('accessToken', body.accessToken);",
          "  pm.collectionVariables.set('refreshToken', body.refreshToken);",
          "  const payload = decodeJwt(body.accessToken);",
          "  if (payload && payload.sub) pm.collectionVariables.set('userId', payload.sub);",
          "}",
          "",
          "let body = null;",
          "try { body = pm.response.json(); } catch (e) {}",
          "if (body && body.accessToken && body.refreshToken) {",
          "  saveTokens(body);",
          "  pm.collectionVariables.unset('retry_after_refresh');",
          "}",
          "",
          "if (pm.response.code !== 401) {",
          "  pm.collectionVariables.unset('retry_after_refresh');",
          "  return;",
          "}",
          "",
          "const currentName = pm.info.requestName || '';",
          "if (currentName === 'Auth - Refresh Token') return;",
          "if (pm.collectionVariables.get('retry_after_refresh') === 'true') {",
          "  pm.collectionVariables.unset('retry_after_refresh');",
          "  return;",
          "}",
          "",
          "const baseUrl = pm.collectionVariables.get('baseUrl');",
          "const userId = pm.collectionVariables.get('userId');",
          "const refreshToken = pm.collectionVariables.get('refreshToken');",
          "if (!baseUrl || !userId || !refreshToken) return;",
          "",
          "pm.collectionVariables.set('retry_after_refresh', 'true');",
          "pm.sendRequest({",
          "  url: `${baseUrl}/auth/refresh`,",
          "  method: 'POST',",
          "  header: { 'Content-Type': 'application/json' },",
          "  body: { mode: 'raw', raw: JSON.stringify({ userId, refreshToken }) }",
          "}, (err, res) => {",
          "  if (err || !res || res.code >= 400) {",
          "    pm.collectionVariables.unset('retry_after_refresh');",
          "    return;",
          "  }",
          "  let refreshBody = null;",
          "  try { refreshBody = res.json(); } catch (e) {}",
          "  if (!refreshBody || !refreshBody.accessToken || !refreshBody.refreshToken) return;",
          "  saveTokens(refreshBody);",
          "  pm.collectionVariables.unset('retry_after_refresh');",
          "  postman.setNextRequest(currentName);",
          "});"
        ]
      }
    }
  ],
  "item": [
    {
      "name": "Auth and Public",
      "item": [
        {
          "name": "Auth - Login",
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{identifier}}\",\n  \"password\": \"{{password}}\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": "{{baseUrl}}/auth/login"
          }
        },
        {
          "name": "Auth - Refresh Token",
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"userId\": \"{{userId}}\",\n  \"refreshToken\": \"{{refreshToken}}\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": "{{baseUrl}}/auth/refresh"
          }
        },
        {
          "name": "Auth - Forgot Password",
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{identifier}}\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": "{{baseUrl}}/auth/forgot-password"
          }
        },
        {
          "name": "Auth - Reset Password",
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"token\": \"{{resetToken}}\",\n  \"newPassword\": \"{{newPassword}}\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": "{{baseUrl}}/auth/reset-password"
          }
        },
        {
          "name": "Signup - Create Pending Registration",
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Mobile User\",\n  \"phone\": \"{{phone}}\",\n  \"email\": \"{{identifier}}\",\n  \"nationalId\": \"29801011234567\",\n  \"personalPhotoId\": \"{{personalPhotoId}}\",\n  \"roleIntent\": \"TENANT\",\n  \"password\": \"{{password}}\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": "{{baseUrl}}/signup"
          }
        }
      ]
    },
    {
      "name": "Community Core",
      "item": [
        {
          "name": "Files - Upload Service Attachment",
          "request": {
            "method": "POST",
            "body": {
              "mode": "formdata",
              "formdata": [
                { "key": "file", "type": "file", "src": "" }
              ]
            },
            "url": "{{baseUrl}}/files/upload/service-attachment"
          }
        },
        {
          "name": "Facilities - List",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/facilities"
          }
        },
        {
          "name": "Bookings - Create",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"facilityId\": \"{{facilityId}}\",\n  \"unitId\": \"{{unitId}}\",\n  \"date\": \"2026-03-01\",\n  \"startTime\": \"18:00\",\n  \"endTime\": \"19:00\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": "{{baseUrl}}/bookings"
          }
        },
        {
          "name": "Bookings - My",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/bookings/me?page=1&limit=20"
          }
        },
        {
          "name": "Service Requests - Create",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"serviceId\": \"{{serviceId}}\",\n  \"unitId\": \"{{unitId}}\",\n  \"description\": \"AC maintenance request\",\n  \"priority\": \"MEDIUM\",\n  \"attachmentIds\": [\"{{attachmentFileId}}\"]\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": "{{baseUrl}}/service-requests"
          }
        },
        {
          "name": "Service Requests - My",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/service-requests/my-requests?page=1&limit=20"
          }
        },
        {
          "name": "Complaints - Create",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"unitId\": \"{{unitId}}\",\n  \"description\": \"Noise complaint\",\n  \"category\": \"Noise\",\n  \"priority\": \"MEDIUM\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": "{{baseUrl}}/complaints"
          }
        },
        {
          "name": "Complaints - By ID",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/complaints/{{complaintId}}"
          }
        },
        {
          "name": "Invoices - By Resident",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/invoices/resident/{{residentId}}"
          }
        },
        {
          "name": "Notifications - My",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/notifications/me?page=1&limit=20"
          }
        },
        {
          "name": "Access QR - Generate",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"unitId\": \"{{unitId}}\",\n  \"type\": \"VISITOR\",\n  \"visitorName\": \"Guest User\",\n  \"validFrom\": \"2026-03-01T12:00:00.000Z\",\n  \"validTo\": \"2026-03-01T13:00:00.000Z\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": "{{baseUrl}}/access-qrcodes"
          }
        },
        {
          "name": "Access QR - List",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/access-qrcodes?unitId={{unitId}}&includeInactive=false"
          }
        }
      ]
    },
    {
      "name": "Admin Essentials",
      "item": [
        {
          "name": "Admin Pending - List",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/admin/pending-registrations"
          }
        },
        {
          "name": "Admin Pending - Approve",
          "request": {
            "method": "PATCH",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"unitId\": \"{{unitId}}\",\n  \"role\": \"TENANT\",\n  \"isPrimary\": false\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": "{{baseUrl}}/admin/pending-registrations/{{pendingRegistrationId}}/approve"
          }
        },
        {
          "name": "Dashboard - Summary",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/dashboard/summary"
          }
        }
      ]
    }
  ],
  "variable": [
