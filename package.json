{
  "name": "community-dashboard",
  "version": "0.0.1",
  "description": "PMS Dashboard and Community App Backend",
  "author": "",
  "private": true,
  "license": "UNLICENSED",
  "prisma": {
    "seed": "node prisma/seed-fast.js"
  },
  "scripts": {
    "prebuild": "npm run prisma:generate",
    "build": "tsc -p tsconfig.build.json",
    "start": "node dist/src/main.js",
    "start:prod": "node dist/src/main.js",
    "prisma:generate": "npx prisma generate --schema prisma/schema.prisma",
    "prisma:migrate": "npx prisma migrate dev --schema prisma/schema.prisma",
    "prisma:push": "npx prisma db push --schema prisma/schema.prisma",
    "prisma:push:reset": "npx prisma db push --schema prisma/schema.prisma --force-reset --accept-data-loss",
    "db:init:fresh": "npm run prisma:generate && npm run prisma:push && npx prisma db seed",
    "db:init:fresh:reset": "npm run prisma:generate && npm run prisma:push:reset && npx prisma db seed",
    "seed:fast": "node prisma/seed-fast.js",
    "seed:fast:reset-rbac": "node -e \"process.env.SEED_RESET_RBAC='true'; require('./prisma/seed-fast.js')\"",
    "seed:full": "npx tsx prisma/seed.ts",
    "audit:prod": "npm audit --omit=dev",
    "audit:prod:gate": "npm audit --omit=dev --json | node scripts/security/audit-prod-gate.js"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1004.0",
    "@nestjs/common": "^11.1.16",
    "@nestjs/core": "^11.1.16",
    "@nestjs/event-emitter": "^3.0.1",
    "@nestjs/jwt": "^11.0.2",
    "@nestjs/passport": "^11.0.5",
    "@nestjs/platform-express": "^11.1.16",
    "@nestjs/schedule": "^6.1.0",
    "@nestjs/swagger": "^11.2.6",
    "@prisma/client": "^5.14.0",
    "@supabase/supabase-js": "^2.87.0",
    "bcrypt": "^6.0.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.3",
    "dayjs": "^1.11.19",
    "dotenv": "^17.2.3",
    "exceljs": "^4.4.0",
    "express": "^5.2.1",
    "firebase-admin": "^13.7.0",
    "is-promise": "^4.0.0",
    "nodemailer": "^7.0.12",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "pdf-lib": "^1.17.1",
    "qrcode": "^1.5.4",
    "reflect-metadata": "^0.2.0",
    "rxjs": "^7.8.1",
    "swagger-ui-express": "^5.0.1"
  },
  "devDependencies": {
    "@types/bcrypt": "^6.0.0",
    "@types/express": "^4.17.25",
    "@types/multer": "^2.1.0",
    "@types/node": "^20.19.29",
    "@types/nodemailer": "^7.0.11",
    "@types/passport-jwt": "^4.0.1",
    "@types/qrcode": "^1.5.6",
    "prisma": "^5.22.0",
    "source-map-support": "^0.5.21",
    "ts-loader": "^9.4.3",
    "typescript": "^5.1.3"
  }
}
