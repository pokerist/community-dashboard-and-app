model User {
  id                    String         @id @default(uuid())
  email                 String?        @unique
  passwordHash          String?
  nameEN                String?
  nameAR                String?
  preferredLanguage     String?
  userStatus            UserStatusEnum @default(ACTIVE)
  phone                 String?
  signupSource          String         @default("dashboard") // "community" or "dashboard"
  requiresOnboarding    Boolean        @default(false)
  onboardingCompletedAt DateTime?
  onboardingStep        String? // 'OTP' | 'PHOTO' | 'ID_UPLOAD' | 'COMPLETE'
  profilePhotoId        String?        @unique
  profilePhoto          File?          @relation("file_profile_photo", fields: [profilePhotoId], references: [id])
  nationalIdFileId      String?        @unique // For delegates and residents
  nationalIdFile        File?          @relation("file_national_id", fields: [nationalIdFileId], references: [id])
  createdAt             DateTime       @default(now())
  updatedAt             DateTime       @updatedAt

  // Authentication
  passwordResetToken          String?
  passwordResetTokenExpiresAt DateTime?

  emailVerificationToken          String?
  emailVerificationTokenExpiresAt DateTime?

  phoneVerificationToken          String?
  phoneVerificationTokenExpiresAt DateTime?

  emailVerifiedAt  DateTime?
  phoneVerifiedAt  DateTime?
  twoFactorEnabled Boolean   @default(false)

  lastLoginAt   DateTime?
  loginAttempts Int       @default(0)
  lockedUntil   DateTime?

  // Relations
  // Roles
  roles UserRole[]

  // Leases (owner/tenant)
  leasesAsOwner        Lease[]       @relation("owner_leases")
  leasesAsTenant       Lease[]       @relation("tenant_leases")
  rentRequestsAsOwner  RentRequest[] @relation("rent_request_owner")
  rentRequestsReviewed RentRequest[] @relation("rent_request_reviewer")

  // Complaints (issued/targeted)
  complaintsReported Complaint[] @relation("reporter")
  complaintsAssigned Complaint[] @relation("complaint_assignee")

  // Violations (issued/targeted)
  violationsIssued   Violation[] @relation("issued_by")
  violationsTargeted Violation[] @relation("violation_target")

  // Invoices
  invoices Invoice[] @relation("user_invoices")

  // Service Requests
  serviceRequests         ServiceRequest[] @relation("creator_requests")
  assignedServiceRequests ServiceRequest[] @relation("assigned_to_service_requests")
  serviceRequestComments  ServiceRequestComment[]
  complaintComments       ComplaintComment[]

  // Attendance
  attendanceLogsRecorded AttendanceLog[] @relation("attendance_recorded_by")

  // Access QRCodes
  qrCodesGenerated AccessQRCode[] @relation("generated_by")
  qrGateOperations AccessQRCode[] @relation("gate_operator")

  // Bookings
  bookings Booking[]

  // Devices
  devices SmartDevice[]

  // Notifications
  notificationsSent        Notification[]            @relation("sender")
  notificationDeviceTokens NotificationDeviceToken[]

  // Status Logs
  statusLogs UserStatusLog[]

  // Referrals
  referrals         Referral[] @relation("referrer")
  convertedReferral Referral?  @relation("converted_user")

  // Specific Roles
  admin    Admin?
  resident Resident?
  owner    Owner?
  tenant   Tenant?
  broker   Broker?
  // Future: hospitalityStaff HospitalityStaff? — added when Hospitality module ships

  // Authentication Tokens
  refreshTokens RefreshToken[]

  // Verification Tokens
  passwordResetTokens              PasswordResetToken[]
  emailVerificationTokens          EmailVerificationToken[]
  phoneVerificationOtps            PhoneVerificationOtp[]
  unitAccesses                     UnitAccess[]
  contractorMembers                ContractorMember[]
  commercialEntityMemberships      CommercialEntityMember[]   @relation("commercial_entity_member_user")
  commercialMembersCreated         CommercialEntityMember[]   @relation("commercial_entity_member_created_by")
  compoundStaffAssignments         CompoundStaff[]            @relation("compound_staff_user")
  compoundStaffAccessGranted       CompoundStaffAccess[]      @relation("compound_staff_access_granted_by")
  compoundStaffGateAccessesGranted CompoundStaffGateAccess[]  @relation("compound_staff_gate_access_granted_by")
  compoundStaffActivitiesAuthored  CompoundStaffActivityLog[] @relation("compound_staff_activity_actor")
  blueCollarSettingsCreated        BlueCollarSetting[]        @relation("blue_collar_setting_created_by")
  blueCollarSettingsUpdated        BlueCollarSetting[]        @relation("blue_collar_setting_updated_by")
  blueCollarRequestsSubmitted      BlueCollarAccessRequest[]  @relation("blue_collar_request_requested_by")
  blueCollarRequestsReviewed       BlueCollarAccessRequest[]  @relation("blue_collar_request_reviewed_by")
  gateEntryOperations              GateEntryLog[]             @relation("gate_entry_operator")
  clubhouseAccessRequests          ClubhouseAccessRequest[]
  ownerUnitContracts               OwnerUnitContract[]        @relation("owner_unit_contract_owner")
  ownerUnitContractsCreated        OwnerUnitContract[]        @relation("owner_unit_contract_created_by")
  profileChangeRequests            ProfileChangeRequest[]     @relation("profile_change_request_user")
  profileChangeReviewed            ProfileChangeRequest[]     @relation("profile_change_request_reviewer")
  familyRequests                   FamilyAccessRequest[]      @relation("family_request_owner")
  familyRequestsReviewed           FamilyAccessRequest[]      @relation("family_request_reviewer")
  familyRequestsActivated          FamilyAccessRequest[]      @relation("family_request_activated_user")
  authorizedRequests               AuthorizedAccessRequest[]  @relation("authorized_request_owner")
  authorizedRequestsReviewed       AuthorizedAccessRequest[]  @relation("authorized_request_reviewer")
  authorizedRequestsActivated      AuthorizedAccessRequest[]  @relation("authorized_request_activated_user")
  homeStaffRequests                HomeStaffAccess[]          @relation("home_staff_request_owner")
  homeStaffRequestsReviewed        HomeStaffAccess[]          @relation("home_staff_request_reviewer")
  violationActionRequests          ViolationActionRequest[]   @relation("violation_action_request_user")
  violationActionReviewed          ViolationActionRequest[]   @relation("violation_action_request_reviewer")
  ownershipTransfersFrom           UnitOwnershipTransfer[]    @relation("ownership_transfer_from_user")
  ownershipTransfersTo             UnitOwnershipTransfer[]    @relation("ownership_transfer_to_user")
  ownershipTransfersBy             UnitOwnershipTransfer[]    @relation("ownership_transfer_by_user")
  permitRequests                   PermitRequest[]            @relation("permit_requester")
  reviewedPermitRequests           PermitRequest[]            @relation("permit_reviewer")
  surveyResponses                  SurveyResponse[]
  surveysCreated                   Survey[]
  orders                           Order[]

  @@index([email])
  @@index([phone])
  @@index([createdAt])
}

model Survey {
  id             String       @id @default(uuid())
  title          String
  description    String?
  targetType     SurveyTarget @default(ALL)
  targetMeta     Json?
  status         SurveyStatus @default(DRAFT)
  publishedAt    DateTime?
  closedAt       DateTime?
  notificationId String?
  createdById    String
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  questions SurveyQuestion[]
  responses SurveyResponse[]
  createdBy User             @relation(fields: [createdById], references: [id])

  @@index([status, createdAt])
  @@index([createdById, createdAt])
}

model SurveyQuestion {
  id           String          @id @default(uuid())
  surveyId     String
  survey       Survey          @relation(fields: [surveyId], references: [id], onDelete: Cascade)
  text         String
  type         SurveyFieldType
  options      Json?
  required     Boolean         @default(true)
  displayOrder Int             @default(0)
  answers      SurveyAnswer[]

  @@index([surveyId, displayOrder])
}

model SurveyResponse {
  id          String         @id @default(uuid())
  surveyId    String
  survey      Survey         @relation(fields: [surveyId], references: [id])
  userId      String
  user        User           @relation(fields: [userId], references: [id])
  submittedAt DateTime       @default(now())
  answers     SurveyAnswer[]

  @@unique([surveyId, userId])
  @@index([surveyId, submittedAt])
}

model SurveyAnswer {
  id          String         @id @default(uuid())
  responseId  String
  response    SurveyResponse @relation(fields: [responseId], references: [id], onDelete: Cascade)
  questionId  String
  question    SurveyQuestion @relation(fields: [questionId], references: [id])
  valueText   String?
  valueNumber Int?
  valueChoice String?

  @@index([responseId])
  @@index([questionId])
}

model Restaurant {
  id           String   @id @default(uuid())
  name         String
  description  String?
  category     String?
  logoFileId   String?
  isActive     Boolean  @default(true)
  displayOrder Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  menuItems MenuItem[]
  orders    Order[]

  @@index([isActive, displayOrder])
  @@index([category])
}

model MenuItem {
  id           String     @id @default(uuid())
  restaurantId String
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  name         String
  description  String?
  price        Decimal    @db.Decimal(10, 2)
  photoFileId  String?
  category     String?
  isAvailable  Boolean    @default(true)
  displayOrder Int        @default(0)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  orderItems OrderItem[]

  @@index([restaurantId, category, displayOrder])
  @@index([isAvailable])
}

model Order {
  id           String      @id @default(uuid())
  orderNumber  String      @unique
  userId       String
  user         User        @relation(fields: [userId], references: [id])
  unitId       String?
  unit         Unit?       @relation(fields: [unitId], references: [id])
  restaurantId String
  restaurant   Restaurant  @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  status       OrderStatus @default(PENDING)
  totalAmount  Decimal     @db.Decimal(10, 2)
  notes        String?
  confirmedAt  DateTime?
  preparedAt   DateTime?
  deliveredAt  DateTime?
  cancelledAt  DateTime?
  cancelReason String?
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  items OrderItem[]

  @@index([restaurantId, status, createdAt])
  @@index([userId, createdAt])
  @@index([unitId, createdAt])
}

model OrderItem {
  id         String   @id @default(uuid())
  orderId    String
  order      Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  menuItemId String
  menuItem   MenuItem @relation(fields: [menuItemId], references: [id])
  quantity   Int
  unitPrice  Decimal  @db.Decimal(10, 2)
  subtotal   Decimal  @db.Decimal(10, 2)
  notes      String?

  @@index([orderId])
  @@index([menuItemId])
}

model Role {
  id               String           @id @default(uuid())
  name             String           @unique
  permissions      RolePermission[]
  users            UserRole[]
  assignedServices Service[]
}

model UserRole {
  userId String
  roleId String

  user User @relation(fields: [userId], references: [id])
  role Role @relation(fields: [roleId], references: [id])

  @@id([userId, roleId])
}

model Admin {
  id        String         @id @default(uuid())
  userId    String         @unique
  user      User           @relation(fields: [userId], references: [id])
  status    UserStatusEnum @default(ACTIVE)
  createdAt DateTime       @default(now())
}

model Resident {
  id           String    @id @default(uuid())
  userId       String    @unique
  user         User      @relation(fields: [userId], references: [id])
  nationalId   String?
  dateOfBirth  DateTime?
  relationship String? // e.g., "spouse", "child", "parent"
  bookings     Booking[]

  residentUnits ResidentUnit[]
  familyMembers FamilyMember[]     @relation("primary_family_members")
  familyOf      FamilyMember?      @relation("family_member_of")
  documents     ResidentDocument[] @relation("resident_documents")
  vehicles      ResidentVehicle[]
}

model ResidentVehicle {
  id                    String   @id @default(uuid())
  residentId            String
  vehicleType           String
  model                 String
  plateNumber           String
  plateNumberNormalized String
  color                 String?
  notes                 String?
  isPrimary             Boolean  @default(false)
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  resident Resident @relation(fields: [residentId], references: [id], onDelete: Cascade)

  @@unique([residentId, plateNumberNormalized])
  @@index([residentId, createdAt])
}

model FamilyMember {
  id                String   @id @default(uuid())
  primaryResidentId String // the owner/tenant
  primaryResident   Resident @relation("primary_family_members", fields: [primaryResidentId], references: [id])

  familyResidentId String   @unique // the family member themselves
  familyResident   Resident @relation("family_member_of", fields: [familyResidentId], references: [id])

  relationship  RelationshipType // CHILD | SPOUSE | PARENT
  status        UserStatusEnum   @default(ACTIVE)
  activatedAt   DateTime         @default(now())
  deactivatedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([primaryResidentId])
  @@index([familyResidentId])
}

model Owner {
  id     String @id @default(uuid())
  userId String @unique
  user   User   @relation(fields: [userId], references: [id])
}

model Tenant {
  id     String @id @default(uuid())
  userId String @unique
  user   User   @relation(fields: [userId], references: [id])
}

model Broker {
  id            String         @id @default(uuid())
  userId        String         @unique
  user          User           @relation(fields: [userId], references: [id])
  agencyName    String?
  licenseNumber String?
  status        UserStatusEnum @default(ACTIVE)
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
}

model Permission {
  id  String @id @default(uuid())
  key String @unique // billing.create_invoice

  rolePermissions RolePermission[]
}

model RolePermission {
  roleId       String
  permissionId String

  role       Role       @relation(fields: [roleId], references: [id])
  permission Permission @relation(fields: [permissionId], references: [id])

  @@id([roleId, permissionId])
}

model Unit {
  id             String         @id @default(uuid())
  projectName    String
  communityId    String?
  clusterId      String?
  gateAccessMode GateAccessMode @default(ALL_GATES)
  allowedGateIds String[]       @default([])
  block          String?
  unitNumber     String
  type           UnitType
  floors         Int?
  bedrooms       Int?
  bathrooms      Int?
  sizeSqm        Float?
  price          Decimal?       @db.Decimal(12, 2)
  status         UnitStatus     @default(AVAILABLE)
  isDelivered    Boolean        @default(false)
  deliveryDate   DateTime?
  isActive       Boolean        @default(true)
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  deletedAt      DateTime?

  // relationships
  serviceRequests ServiceRequest[]
  residents       ResidentUnit[]
  community       Community?       @relation(fields: [communityId], references: [id], onDelete: SetNull)
  cluster         Cluster?         @relation(fields: [clusterId], references: [id], onDelete: SetNull)
  leases          Lease[]
  invoices        Invoice[]
  bookings        Booking[]
  orders          Order[]
  smartDevices    SmartDevice[]
  accessQRCodes   AccessQRCode[]
  complaints      Complaint[]
  violations      Violation[]
  incidents       Incident[]
  unitFees        UnitFee[]

  accessGrants            AccessGrant[]
  unitAccesses            UnitAccess[]
  clubhouseAccessRequests ClubhouseAccessRequest[]

  workers                  Worker[]
  blueCollarAccessRequests BlueCollarAccessRequest[]
  gateUnitAccesses         GateUnitAccess[]
  gateEntryLogs            GateEntryLog[]
  commercialEntities       CommercialEntity[]
  ownerUnitContracts       OwnerUnitContract[]
  rentRequests             RentRequest[]
  familyAccessRequests     FamilyAccessRequest[]
  authorizedAccessRequests AuthorizedAccessRequest[]
  homeStaffAccesses        HomeStaffAccess[]
  ownershipTransfers       UnitOwnershipTransfer[]
  permitRequests           PermitRequest[]

  @@index([communityId])
  @@index([clusterId])
}

model Cluster {
  id           String    @id @default(uuid())
  communityId  String
  name         String
  code         String?
  displayOrder Int       @default(0)
  description  String?
  isActive     Boolean   @default(true)
  deletedAt    DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  community Community @relation(fields: [communityId], references: [id], onDelete: Cascade)
  units     Unit[]

  @@unique([communityId, name])
  @@index([communityId])
  @@index([communityId, displayOrder])
  @@index([isActive])
  @@index([deletedAt])
}

model Community {
  id                String      @id @default(uuid())
  name              String      @unique
  code              String?     @unique
  isActive          Boolean     @default(true)
  allowedEntryRoles EntryRole[] @default([])
  displayOrder      Int         @default(0)
  createdAt         DateTime    @default(now())
  updatedAt         DateTime    @updatedAt

  units              Unit[]
  clusters           Cluster[]
  gates              Gate[]
  commercialEntities CommercialEntity[]
  compoundStaff      CompoundStaff[]
  blueCollarSetting  BlueCollarSetting?
  blueCollarHolidays BlueCollarHoliday[]
}

model Gate {
  id                       String       @id @default(uuid())
  communityId              String
  name                     String
  code                     String?
  status                   EntityStatus @default(ACTIVE)
  allowedRoles             GateRole[]   @default([VISITOR])
  etaMinutes               Int?
  isActive                 Boolean      @default(true)
  isVisitorRequestRequired Boolean      @default(false)
  createdAt                DateTime     @default(now())
  updatedAt                DateTime     @updatedAt
  deletedAt                DateTime?

  community             Community                 @relation(fields: [communityId], references: [id], onDelete: Cascade)
  unitAccesses          GateUnitAccess[]
  entryLogs             GateEntryLog[]
  compoundStaffAccesses CompoundStaffGateAccess[]

  @@unique([communityId, name])
  @@index([communityId])
  @@index([communityId, isActive])
  @@index([status])
  @@index([deletedAt])
}

model GateUnitAccess {
  id        String    @id @default(uuid())
  gateId    String
  unitId    String
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  gate Gate @relation(fields: [gateId], references: [id], onDelete: Cascade)
  unit Unit @relation(fields: [unitId], references: [id], onDelete: Cascade)

  @@unique([gateId, unitId])
  @@index([gateId])
  @@index([unitId])
  @@index([deletedAt])
}

model GateEntryLog {
  id                  String          @id @default(uuid())
  gateId              String?
  qrCodeId            String?
  unitId              String?
  direction           GateDirection
  result              GateScanResult  @default(ALLOWED)
  scanRole            GateAccessRole?
  operatorUserId      String?
  visitorNameSnapshot String?
  scannedAt           DateTime        @default(now())
  notes               String?
  createdAt           DateTime        @default(now())
  updatedAt           DateTime        @updatedAt
  deletedAt           DateTime?

  gate         Gate?         @relation(fields: [gateId], references: [id], onDelete: SetNull)
  qrCode       AccessQRCode? @relation(fields: [qrCodeId], references: [id], onDelete: SetNull)
  unit         Unit?         @relation(fields: [unitId], references: [id], onDelete: SetNull)
  operatorUser User?         @relation("gate_entry_operator", fields: [operatorUserId], references: [id], onDelete: SetNull)

  @@index([gateId])
  @@index([qrCodeId])
  @@index([unitId])
  @@index([operatorUserId])
  @@index([scannedAt])
  @@index([direction])
  @@index([result])
  @@index([deletedAt])
}

// ⚠️ residentUnit is legacy. Do NOT use for permission checks.
// Use unitAccess instead for all access control and permissions.
model ResidentUnit {
  id              String          @id @default(uuid())
  resident        Resident        @relation(fields: [residentId], references: [id])
  residentId      String
  unit            Unit            @relation(fields: [unitId], references: [id])
  unitId          String
  assignedAt      DateTime        @default(now())
  isPrimary       Boolean         @default(false)
  finishingStatus FinishingStatus @default(NOT_STARTED)

  @@unique([residentId, unitId])
  @@index([unitId])
  @@index([residentId])
  @@index([residentId, isPrimary])
}

model UnitAccess {
  id     String @id @default(uuid())
  unitId String
  userId String

  role         UnitAccessRole
  delegateType DelegateType?
  startsAt     DateTime
  endsAt       DateTime?

  grantedBy String // owner userId or admin userId
  status    AccessStatus // ACTIVE / REVOKED / EXPIRED

  source String? // OWNER_DELEGATION | ADMIN_ASSIGNMENT | FAMILY_AUTO | TENANT_AUTO

  canViewFinancials  Boolean  @default(false)
  canReceiveBilling  Boolean  @default(false)
  canBookFacilities  Boolean  @default(true)
  canGenerateQR      Boolean  @default(false)
  canManageWorkers   Boolean  @default(false)
  qrScopes           String[] @default([])
  featurePermissions Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  unit Unit @relation(fields: [unitId], references: [id])
  user User @relation(fields: [userId], references: [id])
}

model AccessProfile {
  id         String       @id @default(uuid())
  fullName   String
  nationalId String
  phone      String?
  photoId    String?
  notes      String?
  status     AccessStatus @default(ACTIVE)
  createdAt  DateTime     @default(now())

  workers Worker[]

  accessGrants AccessGrant[]
}

model Contractor {
  id     String       @id @default(uuid())
  name   String
  status EntityStatus @default(ACTIVE)

  workers                  Worker[]
  blueCollarAccessRequests BlueCollarAccessRequest[]
  members                  ContractorMember[]
}

model ContractorMember {
  id           String             @id @default(uuid())
  contractorId String
  userId       String
  role         ContractorRoleEnum // ADMIN, SUPERVISOR, VIEWER
  status       MemberStatusEnum

  contractor Contractor @relation(fields: [contractorId], references: [id])
  user       User       @relation(fields: [userId], references: [id])

  createdAt DateTime @default(now())
}

model Worker {
  id              String       @id @default(uuid())
  accessProfileId String
  contractorId    String
  jobType         String?
  status          EntityStatus @default(ACTIVE)

  unitId String
  unit   Unit   @relation(fields: [unitId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  accessProfile            AccessProfile             @relation(fields: [accessProfileId], references: [id])
  contractor               Contractor                @relation(fields: [contractorId], references: [id])
  homeStaffAccesses        HomeStaffAccess[]
  blueCollarAccessRequests BlueCollarAccessRequest[]
}

model BlueCollarSetting {
  id String @id @default(uuid())

  communityId String
  community   Community @relation(fields: [communityId], references: [id], onDelete: Cascade)

  workDays              BlueCollarWeekDay[] @default([])
  workStartTime         String?
  workEndTime           String?
  workingHoursStart     String              @default("07:00")
  workingHoursEnd       String              @default("18:00")
  allowedDays           Int[]               @default([1, 2, 3, 4, 5])
  holidays              Json?
  termsAndConditions    String?
  termsVersion          Int                 @default(1)
  requiresAdminApproval Boolean             @default(true)

  createdById String?
  createdBy   User?   @relation("blue_collar_setting_created_by", fields: [createdById], references: [id], onDelete: SetNull)
  updatedById String?
  updatedBy   User?   @relation("blue_collar_setting_updated_by", fields: [updatedById], references: [id], onDelete: SetNull)

  accessRequests BlueCollarAccessRequest[]

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@unique([communityId])
  @@index([communityId])
  @@index([createdById])
  @@index([updatedById])
  @@index([deletedAt])
}

model BlueCollarHoliday {
  id          String   @id @default(uuid())
  communityId String
  date        DateTime
  label       String
  createdAt   DateTime @default(now())

  community Community @relation(fields: [communityId], references: [id], onDelete: Cascade)

  @@unique([communityId, date])
  @@index([communityId, date])
}

model BlueCollarAccessRequest {
  id String @id @default(uuid())

  workerId String
  worker   Worker @relation(fields: [workerId], references: [id], onDelete: Cascade)

  unitId String
  unit   Unit   @relation(fields: [unitId], references: [id], onDelete: Cascade)

  contractorId String
  contractor   Contractor @relation(fields: [contractorId], references: [id], onDelete: Cascade)

  settingId String?
  setting   BlueCollarSetting? @relation(fields: [settingId], references: [id], onDelete: SetNull)

  requestedById String
  requestedBy   User    @relation("blue_collar_request_requested_by", fields: [requestedById], references: [id], onDelete: Cascade)
  reviewedById  String?
  reviewedBy    User?   @relation("blue_collar_request_reviewed_by", fields: [reviewedById], references: [id], onDelete: SetNull)

  qrCodeId String?       @unique
  qrCode   AccessQRCode? @relation(fields: [qrCodeId], references: [id], onDelete: SetNull)

  idDocumentRef      String?
  status             BlueCollarRequestStatus @default(PENDING)
  requestedValidFrom DateTime
  requestedValidTo   DateTime
  gates              String[]                @default([])
  notes              String?
  rejectionReason    String?
  reviewedAt         DateTime?

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@index([workerId])
  @@index([unitId])
  @@index([contractorId])
  @@index([settingId])
  @@index([requestedById])
  @@index([reviewedById])
  @@index([qrCodeId])
  @@index([status])
  @@index([createdAt])
  @@index([deletedAt])
}

model CommercialEntity {
  id          String  @id @default(uuid())
  name        String
  description String?

  communityId String
  community   Community @relation(fields: [communityId], references: [id], onDelete: Cascade)

  unitId String
  unit   Unit   @relation(fields: [unitId], references: [id], onDelete: Restrict)

  isActive Boolean                  @default(true)
  members  CommercialEntityMember[]
  staff    CompoundStaff[]

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@unique([communityId, name])
  @@index([communityId])
  @@index([unitId])
  @@index([isActive])
  @@index([deletedAt])
}

model CommercialEntityMember {
  id          String                     @id @default(uuid())
  entityId    String
  userId      String
  role        CommercialEntityMemberRole
  permissions Json?
  createdById String?
  isActive    Boolean                    @default(true)

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  entity    CommercialEntity @relation(fields: [entityId], references: [id], onDelete: Cascade)
  user      User             @relation("commercial_entity_member_user", fields: [userId], references: [id], onDelete: Cascade)
  createdBy User?            @relation("commercial_entity_member_created_by", fields: [createdById], references: [id], onDelete: SetNull)

  @@unique([entityId, userId])
  @@index([entityId])
  @@index([userId])
  @@index([createdById])
  @@index([role])
  @@index([isActive])
  @@index([deletedAt])
}

model Department {
  id          String   @id @default(uuid())
  name        String   @unique
  code        String?  @unique
  description String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  staffMembers CompoundStaff[]
}

model CompoundStaff {
  id                 String                     @id @default(uuid())
  communityId        String?
  commercialEntityId String?
  userId             String?
  departmentId       String?
  fullName           String
  phone              String
  nationalId         String
  photoFileId        String?                    @unique
  profession         String
  jobTitle           String?
  workSchedule       Json?
  contractFrom       DateTime?
  contractTo         DateTime?
  status             CompoundStaffStatus        @default(ACTIVE)
  isActive           Boolean                    @default(true)
  accesses           CompoundStaffAccess[]
  schedules          CompoundStaffSchedule[]
  gateAccesses       CompoundStaffGateAccess[]
  activityLogs       CompoundStaffActivityLog[]
  attendanceLogs     AttendanceLog[]
  createdAt          DateTime                   @default(now())
  updatedAt          DateTime                   @updatedAt
  deletedAt          DateTime?

  community        Community?        @relation(fields: [communityId], references: [id], onDelete: SetNull)
  commercialEntity CommercialEntity? @relation(fields: [commercialEntityId], references: [id], onDelete: SetNull)
  user             User?             @relation("compound_staff_user", fields: [userId], references: [id], onDelete: SetNull)
  photoFile        File?             @relation("compound_staff_photo", fields: [photoFileId], references: [id], onDelete: SetNull)
  department       Department?       @relation(fields: [departmentId], references: [id], onDelete: SetNull)

  @@unique([communityId, nationalId])
  @@index([userId])
  @@index([communityId])
  @@index([commercialEntityId])
  @@index([profession])
  @@index([contractTo])
  @@index([status])
  @@index([isActive])
  @@index([deletedAt])
}

model CompoundStaffAccess {
  id          String                  @id @default(uuid())
  staffId     String
  staff       CompoundStaff           @relation(fields: [staffId], references: [id], onDelete: Cascade)
  permission  CompoundStaffPermission
  isGranted   Boolean                 @default(true)
  grantedById String?
  grantedBy   User?                   @relation("compound_staff_access_granted_by", fields: [grantedById], references: [id], onDelete: SetNull)
  createdAt   DateTime                @default(now())
  updatedAt   DateTime                @updatedAt
  deletedAt   DateTime?

  @@unique([staffId, permission])
  @@index([staffId])
  @@index([permission])
  @@index([grantedById])
  @@index([deletedAt])
}

model CompoundStaffSchedule {
  id        String            @id @default(uuid())
  staffId   String
  dayOfWeek BlueCollarWeekDay
  startTime String?
  endTime   String?
  notes     String?
  isActive  Boolean           @default(true)
  createdAt DateTime          @default(now())
  updatedAt DateTime          @updatedAt

  staff CompoundStaff @relation(fields: [staffId], references: [id], onDelete: Cascade)

  @@unique([staffId, dayOfWeek])
  @@index([staffId])
  @@index([isActive])
}

model CompoundStaffGateAccess {
  id          String          @id @default(uuid())
  staffId     String
  gateId      String
  directions  GateDirection[] @default([ENTRY, EXIT])
  isActive    Boolean         @default(true)
  grantedById String?
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  staff     CompoundStaff @relation(fields: [staffId], references: [id], onDelete: Cascade)
  gate      Gate          @relation(fields: [gateId], references: [id], onDelete: Cascade)
  grantedBy User?         @relation("compound_staff_gate_access_granted_by", fields: [grantedById], references: [id], onDelete: SetNull)

  @@unique([staffId, gateId])
  @@index([staffId])
  @@index([gateId])
  @@index([isActive])
  @@index([grantedById])
}

model CompoundStaffActivityLog {
  id          String   @id @default(uuid())
  staffId     String
  actorUserId String?
  action      String
  metadata    Json?
  createdAt   DateTime @default(now())

  staff     CompoundStaff @relation(fields: [staffId], references: [id], onDelete: Cascade)
  actorUser User?         @relation("compound_staff_activity_actor", fields: [actorUserId], references: [id], onDelete: SetNull)

  @@index([staffId])
  @@index([actorUserId])
  @@index([createdAt])
}

model AttendanceLog {
  id          String    @id @default(uuid())
  staffId     String
  clockInAt   DateTime  @default(now())
  clockOutAt  DateTime?
  durationMin Int?      // calculated on clock-out
  notes       String?
  recordedById String?  // admin user who recorded (null = self-clock)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  staff      CompoundStaff @relation(fields: [staffId], references: [id], onDelete: Cascade)
  recordedBy User?         @relation("attendance_recorded_by", fields: [recordedById], references: [id], onDelete: SetNull)

  @@index([staffId, clockInAt])
  @@index([clockInAt])
  @@index([recordedById])
}

model File {
  id        String       @id @default(uuid())
  key       String       @unique // storage path or supabase file key
  name      String
  mimeType  String?
  size      Int?
  category  FileCategory
  createdAt DateTime     @default(now())

  // optional polymorphic relations
  profilePhotoOf       User?          @relation("file_profile_photo")
  nationalIdOf         User?          @relation("file_national_id")
  compoundStaffPhotoOf CompoundStaff? @relation("compound_staff_photo")
  attachments          Attachment[]
  leaseContract        Lease?         @relation("lease_contract")

  pendingRegistrationPhotos      PendingRegistration[] @relation("pending_reg_photo")
  pendingRegistrationNationalIds PendingRegistration[] @relation("pending_reg_national_id")
  documents              ResidentDocument[]    @relation("file_documents")
  ownerUnitContracts     OwnerUnitContract[]   @relation("owner_unit_contract_file")
  ownerInstallments      OwnerInstallment[]    @relation("owner_installment_reference_file")
  rentRequestContracts   RentRequest[]         @relation("rent_request_contract_file")
  rentRequestNationalIds RentRequest[]         @relation("rent_request_national_id_file")
}

model OwnerUnitContract {
  id               String           @id @default(uuid())
  ownerUserId      String
  unitId           String
  contractFileId   String?
  contractSignedAt DateTime?
  paymentMode      OwnerPaymentMode @default(CASH)
  notes            String?
  archivedAt       DateTime?
  createdById      String?
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt

  ownerUser    User               @relation("owner_unit_contract_owner", fields: [ownerUserId], references: [id], onDelete: Cascade)
  unit         Unit               @relation(fields: [unitId], references: [id], onDelete: Cascade)
  contractFile File?              @relation("owner_unit_contract_file", fields: [contractFileId], references: [id])
  createdBy    User?              @relation("owner_unit_contract_created_by", fields: [createdById], references: [id])
  installments OwnerInstallment[]

  @@unique([ownerUserId, unitId])
  @@index([unitId])
  @@index([paymentMode])
}

model UnitOwnershipTransfer {
  id                           String                @id @default(uuid())
  unitId                       String
  fromUserId                   String
  toUserId                     String
  transferMode                 OwnershipTransferMode
  movedContractId              String?
  createdContractId            String?
  transferredInstallmentsCount Int                   @default(0)
  transferredById              String
  notes                        String?
  createdAt                    DateTime              @default(now())

  unit              Unit @relation(fields: [unitId], references: [id], onDelete: Cascade)
  fromUser          User @relation("ownership_transfer_from_user", fields: [fromUserId], references: [id], onDelete: Cascade)
  toUser            User @relation("ownership_transfer_to_user", fields: [toUserId], references: [id], onDelete: Cascade)
  transferredByUser User @relation("ownership_transfer_by_user", fields: [transferredById], references: [id], onDelete: Cascade)

  @@index([unitId, createdAt])
  @@index([fromUserId, createdAt])
  @@index([toUserId, createdAt])
}

model OwnerInstallment {
  id                  String                 @id @default(uuid())
  ownerUnitContractId String
  sequence            Int
  referenceFileId     String?
  referencePageIndex  Int?
  dueDate             DateTime
  amount              Decimal                @db.Decimal(12, 2)
  status              OwnerInstallmentStatus @default(PENDING)
  paidAt              DateTime?
  reminderSentAt      DateTime?
  overdueNotifiedAt   DateTime?
  notes               String?
  createdAt           DateTime               @default(now())
  updatedAt           DateTime               @updatedAt

  ownerUnitContract OwnerUnitContract @relation(fields: [ownerUnitContractId], references: [id], onDelete: Cascade)
  referenceFile     File?             @relation("owner_installment_reference_file", fields: [referenceFileId], references: [id])

  @@unique([ownerUnitContractId, sequence])
  @@index([dueDate, status])
}

model ResidentDocument {
  id         String       @id @default(uuid())
  residentId String
  type       FileCategory
  fileId     String

  resident Resident @relation("resident_documents", fields: [residentId], references: [id])
  file     File     @relation("file_documents", fields: [fileId], references: [id])

  createdAt DateTime @default(now())

  @@unique([residentId, type])
  @@index([residentId])
}

model Attachment {
  id       String @id @default(uuid())
  file     File   @relation(fields: [fileId], references: [id])
  fileId   String
  entityId String // ID of the entity this attachment belongs to
  entity   String // e.g., 'SERVICE_REQUEST', 'COMPLAINT', 'INCIDENT', 'VIOLATION'

  // Explicit relations (keep for backward compatibility, but prefer entity/entityId pattern)
  serviceRequestId String?
  invoiceId        String?
  incidentId       String?

  serviceRequest ServiceRequest? @relation("ServiceRequestAttachments", fields: [serviceRequestId], references: [id])
  invoice        Invoice?        @relation("InvoiceDocuments", fields: [invoiceId], references: [id])
  incident       Incident?       @relation("IncidentAttachments", fields: [incidentId], references: [id])

  createdAt DateTime @default(now())
}

model Service {
  id              String           @id @default(uuid())
  name            String
  category        ServiceCategory
  displayOrder    Int              @default(0)
  iconName        String?
  iconTone        String           @default("auto")
  unitEligibility EligibilityType  @default(ALL)
  processingTime  Int?
  description     String?
  status          Boolean          @default(true)
  isUrgent        Boolean          @default(false)
  startingPrice   Decimal?         @db.Decimal(12, 2)
  slaHours        Int?
  assignedRoleId  String?
  assignedRole    Role?            @relation(fields: [assignedRoleId], references: [id])
  revenueTotal    Decimal          @default(0) @db.Decimal(12, 2)
  formFields      ServiceField[]
  requests        ServiceRequest[]
  totalRequests   Int?             @default(0)
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  @@index([assignedRoleId])
}

model ServiceField {
  id          String                     @id @default(uuid())
  service     Service                    @relation(fields: [serviceId], references: [id])
  serviceId   String
  label       String
  type        ServiceFieldType
  placeholder String?
  required    Boolean                    @default(false)
  order       Int?                       @default(0)
  fieldValues ServiceRequestFieldValue[]
}

model ServiceRequest {
  id             String                     @id @default(uuid())
  service        Service                    @relation(fields: [serviceId], references: [id])
  serviceId      String
  unit           Unit?                      @relation(fields: [unitId], references: [id])
  unitId         String?
  createdBy      User                       @relation("creator_requests", fields: [createdById], references: [id])
  createdById    String
  assignedTo     User?                      @relation("assigned_to_service_requests", fields: [assignedToId], references: [id])
  assignedToId   String?
  status         ServiceRequestStatus       @default(NEW)
  priority       Priority                   @default(MEDIUM)
  description    String
  fieldValues    ServiceRequestFieldValue[]
  attachments    Attachment[]               @relation("ServiceRequestAttachments")
  comments       ServiceRequestComment[]
  requestedAt    DateTime                   @default(now())
  slaBreachedAt  DateTime?
  resolvedAt     DateTime?
  closedAt       DateTime?
  assignedAt     DateTime?
  customerRating Int?
  internalNotes  String?
  updatedAt      DateTime                   @updatedAt
  invoices       Invoice[]

  @@index([requestedAt])
  @@index([status, requestedAt])
  @@index([assignedToId, requestedAt])
  @@index([slaBreachedAt])
}

model PermitType {
  id           String          @id @default(uuid())
  name         String          @unique
  slug         String          @unique
  category     PermitCategory
  description  String?
  isActive     Boolean         @default(true)
  displayOrder Int             @default(0)
  fields       PermitField[]
  requests     PermitRequest[]
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt
}

model PermitField {
  id           String                    @id @default(uuid())
  permitTypeId String
  permitType   PermitType                @relation(fields: [permitTypeId], references: [id])
  label        String
  type         ServiceFieldType
  placeholder  String?
  required     Boolean                   @default(false)
  displayOrder Int                       @default(0)
  fieldValues  PermitRequestFieldValue[]

  @@index([permitTypeId, displayOrder])
}

model PermitRequest {
  id              String                    @id @default(uuid())
  requestNumber   String                    @unique
  permitTypeId    String
  permitType      PermitType                @relation(fields: [permitTypeId], references: [id])
  unitId          String
  unit            Unit                      @relation(fields: [unitId], references: [id])
  requestedById   String
  requestedBy     User                      @relation("permit_requester", fields: [requestedById], references: [id])
  status          PermitStatus              @default(PENDING)
  reviewedById    String?
  reviewedBy      User?                     @relation("permit_reviewer", fields: [reviewedById], references: [id])
  reviewedAt      DateTime?
  rejectionReason String?
  notes           String?
  fieldValues     PermitRequestFieldValue[]
  createdAt       DateTime                  @default(now())
  updatedAt       DateTime                  @updatedAt

  @@index([permitTypeId, createdAt])
  @@index([status, createdAt])
  @@index([unitId, createdAt])
  @@index([requestedById, createdAt])
}

model PermitRequestFieldValue {
  id          String        @id @default(uuid())
  requestId   String
  request     PermitRequest @relation(fields: [requestId], references: [id])
  fieldId     String
  field       PermitField   @relation(fields: [fieldId], references: [id])
  valueText   String?
  valueNumber Float?
  valueBool   Boolean?
  valueDate   DateTime?

  @@index([requestId])
  @@index([fieldId])
}

model ServiceRequestComment {
  id          String         @id @default(uuid())
  request     ServiceRequest @relation(fields: [requestId], references: [id], onDelete: Cascade)
  requestId   String
  createdBy   User           @relation(fields: [createdById], references: [id], onDelete: Cascade)
  createdById String
  body        String
