# Expo Push (Expo Go / Expo push tokens)
EXPO_PUSH_ACCESS_TOKEN=
EXPO_PUSH_MOCK_MODE=true

# Integration settings encryption key (required for at-rest encryption of integration secrets)
SETTINGS_ENCRYPTION_KEY=

# File storage (required for uploads/streams in production)
# Fallback-first storage routing
STORAGE_PROVIDER=LOCAL
# S3-compatible
S3_BUCKET=
S3_REGION=
S3_ENDPOINT=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_FORCE_PATH_STYLE=true
# Supabase
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
