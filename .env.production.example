# Production backend environment (PM2 + direct port deployment)
# Copy to `.env.production` on the server and fill the required secrets.

# Server binding
PORT=4003

# Database (auto-provisioned by deploy.sh for zero-touch demo if placeholders remain)
DATABASE_URL=postgresql://USER:PASSWORD@127.0.0.1:5432/community_dashboard?schema=public
DIRECT_URL=postgresql://USER:PASSWORD@127.0.0.1:5432/community_dashboard?schema=public
# For local server demo deploys, deploy.sh may rewrite these to a Unix socket URL (for example port 5433 with host=/var/run/postgresql).
AUTO_LOCAL_DB_PASSWORD=community123

# Auth / security (demo default, same as local setup to avoid token mismatch surprises)
JWT_ACCESS_SECRET=change-me-in-dev

# CORS / frontend integration
CORS_ORIGIN=http://108.61.174.92:4002
FRONTEND_URL=http://108.61.174.92:4002
# Recommended production:
# CORS_ORIGIN=https://community-admin.example.com
# FRONTEND_URL=https://community-admin.example.com

# Feature flags
ENABLE_PENDING_REGISTRATIONS=false
ENABLE_PUBLIC_SIGNUP=false
ENABLE_REFERRAL_SIGNUP=false
QR_ENFORCE_SINGLE_ACTIVE=false

# HikCentral integration (set mock=true if not integrating yet)
HIKCENTRAL_MOCK=true
HIKCENTRAL_BASE_URL=
HIKCENTRAL_API_KEY=
HIKCENTRAL_QR_CREATE_PATH=

# Email (SMTP)
FROM_EMAIL=
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
EMAIL_MOCK_MODE=false
RESEND_API_KEY=re_KDFhso3u_PMzh4GMhd8z6iKcf6CXct9Pn
RESEND_FROM_EMAIL=no-reply@your-verified-domain.com
RESEND_FROM_NAME=Alkarma Community

# Twilio SMS
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=
TWILIO_MOCK_MODE=true

# FCM Push (native device tokens)
# Option A: full service account JSON
FCM_SERVICE_ACCOUNT_JSON=
# Option B: split fields
FCM_PROJECT_ID=sss-community-app
