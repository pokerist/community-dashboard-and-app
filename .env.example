# Database (required) - aligned with current demo/server runtime defaults
DATABASE_URL=postgresql://community@localhost:5433/community_dashboard?schema=public&host=/var/run/postgresql
DIRECT_URL=postgresql://community@localhost:5433/community_dashboard?schema=public&host=/var/run/postgresql
PORT=3001
NODE_ENV=development
ALLOW_DEMO_RESET=true

# Auth (demo default used by deploy flow)
JWT_ACCESS_SECRET=change-me-in-dev

# Local web clients (admin-web / future mobile web tools)
CORS_ORIGIN=http://localhost:4173,http://127.0.0.1:4173,http://localhost:5173,http://127.0.0.1:5173
FRONTEND_URL=http://localhost:4173

# Feature flags
ENABLE_PENDING_REGISTRATIONS=false
ENABLE_PUBLIC_SIGNUP=false
ENABLE_REFERRAL_SIGNUP=false
QR_ENFORCE_SINGLE_ACTIVE=false

# HikCentral integration (use mock in local unless real integration is configured)
HIKCENTRAL_MOCK=true
HIKCENTRAL_BASE_URL=
HIKCENTRAL_API_KEY=
HIKCENTRAL_QR_CREATE_PATH=

# Notifications / email (optional in local)
FROM_EMAIL=no-reply@hpd-lc.com
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
EMAIL_MOCK_MODE=false
RESEND_API_KEY=re_KDFhso3u_PMzh4GMhd8z6iKcf6CXct9Pn
RESEND_FROM_EMAIL=no-reply@hpd-lc.com
RESEND_FROM_NAME=Alkarma Community

# Twilio SMS (optional in local; defaults to mock if not configured)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=
TWILIO_MOCK_MODE=true

# FCM Push (optional in local; defaults to mock if not configured)
# Option A: provide full JSON string (escaped newlines)
FCM_SERVICE_ACCOUNT_JSON=
# Option B: provide separate fields
FCM_PROJECT_ID=
FCM_CLIENT_EMAIL=
FCM_PRIVATE_KEY=
FCM_MOCK_MODE=true

# Expo Push (optional in local; can work without access token in many dev setups)
EXPO_PUSH_ACCESS_TOKEN=
EXPO_PUSH_MOCK_MODE=false

# Integration settings encryption (recommended when editing integrations from dashboard)
SETTINGS_ENCRYPTION_KEY=

# File storage (optional for app boot now; required for file upload/stream endpoints)
# Fallback-first storage routing:
# STORAGE_PROVIDER=LOCAL|S3|SUPABASE (default LOCAL)
STORAGE_PROVIDER=LOCAL
# S3-compatible
S3_BUCKET=
S3_REGION=
S3_ENDPOINT=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_FORCE_PATH_STYLE=true
# Supabase
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
